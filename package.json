{
  "name": "graveruz-nextjs",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "migrate-blog": "node scripts/migrate-blog.js",
    "preview": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "deploy": "npm run build && npx opennextjs-cloudflare build && npx wrangler deploy --dry-run --outdir=.open-next/bundle && cp .open-next/bundle/worker.js .open-next/assets/_worker.js && npx wrangler pages deploy .open-next/assets --project-name=graveruz-nextjs",
    "smoke-test": "node scripts/smoke-test.js"
  },
  "dependencies": {
    "@mdx-js/loader": "^3.1.0",
    "@mdx-js/react": "^3.1.0",
    "@next/mdx": "15.2.9",
    "gray-matter": "^4.0.3",
    "next": "15.2.9",
    "next-mdx-remote": "^6.0.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "reading-time": "^1.5.0"
  },
  "devDependencies": {
    "@opennextjs/cloudflare": "^1.17.1",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "autoprefixer": "^10.0.1",
    "esbuild": "^0.27.3",
    "postcss": "^8",
    "tailwindcss": "^3.4.1",
    "typescript": "^5",
    "wrangler": "^4.71.0"
  }
}
