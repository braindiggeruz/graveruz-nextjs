{
  "name": "graveruz-nextjs",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "migrate-blog": "node scripts/migrate-blog.js",
    "build:cf": "npx vercel build --yes && npx @cloudflare/next-on-pages --skip-build",
