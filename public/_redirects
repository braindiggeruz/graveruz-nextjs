# Root → default locale
# CRITICAL: Must be 301 (permanent), not 302 (temporary).
# A 302 signals to Google that the redirect is temporary and prevents PageRank consolidation.
# Google may treat / as a separate canonical instead of passing authority to /ru/.
/  /ru/  301

# Old URLs without locale prefix → RU
/blog  /ru/blog/  301
/blog/*  /ru/blog/:splat  301
/catalog-products  /ru/catalog-products/  301
/products/*  /ru/products/:splat  301
/engraved-gifts  /ru/engraved-gifts/  301
/guarantees  /ru/guarantees/  301
/contacts  /ru/contacts/  301
/thanks  /ru/thanks/  301
# Collapsed double-redirect chains: /process -> /ru/process -> /ru  (was 2 hops)
/process  /ru/  301
# Collapsed double-redirect chains: /watches-with-logo -> /ru/watches-with-logo -> /ru/products/neo-watches
/watches-with-logo  /ru/products/neo-watches/  301
# Collapsed double-redirect chains: /lighters-engraving -> /ru/lighters-engraving -> /ru/products/lighters
/lighters-engraving  /ru/products/lighters/  301

