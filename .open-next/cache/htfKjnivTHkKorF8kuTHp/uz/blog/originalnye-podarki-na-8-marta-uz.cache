sName\":\"text-base font-semibold text-white mb-2 line-clamp-2\",\"children\":[\"$\",\"$L12\",null,{\"href\":\"/uz/blog/8-mart-xodimlarga-sovgalar\",\"className\":\"hover:text-teal-500 transition\",\"children\":\"8 Mart xodim ayollarga sovg'alar: 15 ta o'yma bilan g'oya | Graver Studio\"}]}],[\"$\",\"p\",null,{\"className\":\"text-gray-400 text-sm line-clamp-2\",\"children\":\"8 Mart uchun xodim ayollarga eng yaxshi sovg'alar. Shaxsiylashtirilgan o'yma bilan sovg'alar: zajigelkadan kundaliklargacha. 1 dona buyurtma, Toshkentga yetkazib berish.\"}]]}],[\"$\",\"article\",\"chto-podarit-devushke-na-8-marta-uz\",{\"className\":\"bg-gray-800/50 rounded-xl p-5 border border-gray-700 hover:border-teal-500 transition\",\"children\":[[\"$\",\"h3\",null,{\"className\":\"text-base font-semibold text-white mb-2 line-clamp-2\",\"children\":[\"$\",\"$L12\",null,{\"href\":\"/uz/blog/chto-podarit-devushke-na-8-marta-uz\",\"className\":\"hover:text-teal-500 transition\",\"children\":\"8-martga qiz do'stga nima sovg'a qilish kerak | Graver Studio\"}]}],[\"$\",\"p\",null,{\"className\":\"text-gray-400 text-sm line-clamp-2\",\"children\":\"Qiz do'stga 8-martga romantik sovg'alar gravirovka bilan. Bosh harflari tushirilgan taqinchoqlar, e'tirof bitilgan soat, juft breloklar. Kunini unutilmas qiling.\"}]]}],[\"$\",\"article\",\"vip-sovga-goyalari\",{\"className\":\"bg-gray-800/50 rounded-xl p-5 border border-gray-700 hover:border-teal-500 transition\",\"children\":[[\"$\",\"h3\",null,{\"className\":\"text-base font-semibold text-white mb-2 line-clamp-2\",\"children\":[\"$\",\"$L12\",null,{\"href\":\"/uz/blog/vip-sovga-goyalari\",\"className\":\"hover:text-teal-500 transition\",\"children\":\"Hamkorlar va mijozlar uchun 15 ta VIP sovg'a g'oyasi | Graver Studio\"}]}],[\"$\",\"p\",null,{\"className\":\"text-gray-400 text-sm line-clamp-2\",\"children\":\"Hamkorlar va VIP mijozlar uchun eng yaxshi sovg'a g'oyalari: premium gravyura, shaxsiylashtirilgan aksessuarlar va eksklyuziv to'plamlar.\"}]]}]]}]]}],[\"$\",\"div\",null,{\"className\":\"mt-12 border-t border-gray-800 pt-8\",\"children\":[\"$\",\"$L12\",null,{\"href\":\"/uz/blog\",\"className\":\"text-teal-500 hover:text-teal-400 transition flex items-center\",\"children\":[\"← \",\"Blogga qaytish\"]}]}]]}]]\nf:[\"$\",\"html\",null,{\"lang\":\"ru\",\"children\":[\"$\",\"body\",null,{\"className\":\"bg-black text-white min-h-screen flex items-center justify-center\",\"children\":[\"$\",\"div\",null,{\"className\":\"text-center px-4\",\"children\":[[\"$\",\"h1\",null,{\"className\":\"text-8xl font-bold text-teal-500 mb-4\",\"children\":\"404\"}],[\"$\",\"h2\",null,{\"className\":\"text-2xl font-semibold text-white mb-4\",\"children\":\"Страница не найдена\"}],[\"$\",\"p\",null,{\"className\":\"text-gray-400 mb-8\",\"children\":\"Запрошенная страница не существует.\"}],[\"$\",\"$L12\",null,{\"href\":\"/ru\",\"className\":\"bg-gradient-to-r from-teal-500 to-cyan-600 text-white px-6 py-3 rounded-lg font-semibold hover:opacity-90 transition\",\"children\":\"На главную\"}]]}]}]}]\n11:[\"$\",\"div\",null,{\"className\":\"min-h-screen flex items-center justify-center px-4\",\"children\":[\"$\",\"div\",null,{\"className\":\"text-center\",\"children\":[[\"$\",\"h1\",null,{\"className\":\"text-8xl font-bold text-teal-500 mb-4\",\"children\":\"404\"}],[\"$\",\"h2\",null,{\"className\":\"text-2xl font-semibold text-white mb-4\",\"children\":\"Страница не найдена\"}],[\"$\",\"p\",null,{\"className\":\"text-gray-400 mb-8\",\"children\":\"Запрошенная страница не существует.\"}],[\"$\",\"$L12\",null,{\"href\":\"/ru\",\"className\":\"bg-gradient-to-r from-teal-500 to-cyan-600 text-white px-6 py-3 rounded-lg font-semibold hover:opacity-90 transition\",\"children\":\"На главную\"}]]}]}]\n13:[[\"$\",\"h2\",null,{\"children\":\"Nima uchun standart sovg'alar endi ish bermaydi?\"}],\"\\n\",[\"$\",\"p\",null,{\"children\":\"Har yili bir xil narsa: gullar, shirinliklar, atirlar. Ayollar buni qadrlashadi, lekin yuraklarining tubida ular o'zgacha bir narsani kutishadi \\\\u2014 \\\"men aynan sen haqingda o'yladim\\\" deydigan sovg'ani.\"}],\"\\n\",[\"$\",\"p\",null,{\"children\":\"Gravirovka qilingan shaxsiylashtirilgan sovg'a \\\\u2014 bu aynan shunday e'tibor belgisi. Bu sizning vaqtingizni sarflab, eng yaqin do'konga shunchaki kirmasdan, tanlov qilganingizni ko'rsatadi.\"}],\"\\n\",[\"$\",\"h2\",null,{\"children\":\"Eng original 5 ta g'oya\"}],\"\\n\",[\"$\",\"h3\",null,{\"children\":\"1. Orqa qopqog'ida gravirovkasi bo'lgan soat\"}],\"\\n\",[\"$\",\"p\",null,{\"children\":[\"Har safar u soatini yechganda, sizning so'zlaringizni ko'radi. Bu samimiy va romantik ishora. Bizning NEO Quartz soatlarimiz \",[\"$\",\"strong\",null,{\"children\":\"750 000 so'mdan\"}],\" boshlanadi va haqiqiy premium buyumdek ko'rinadi.\"]}],\"\\n\",[\"$\",\"h3\",null,{\"children\":\"2. Iqtibos tushirilgan zajigalka\"}],\"\\n\",[\"$\",\"p\",null,{\"children\":\"Kutilmagan eshitilishi mumkin, ammo chiroyli iqtibos yoki sana tushirilgan metall zajigalka \\\\u2014 bu ayollar sumkasida olib yuradigan zamonaviy aksessuardir. Ayniqsa, chekuvchi ayollar orasida yoki dekorativ buyum sifatida mashhur.\"}],\"\\n\",[\"$\",\"h3\",null,{\"children\":\"3. Ismli brelok\"}],\"\\n\",[\"$\",\"p\",null,{\"children\":\"Oddiy, ammo juda shaxsiy sovg'a. Har safar u kalitlarini olganda, o'z ismini yoki sizning bosh harflaringizni yonma-yon ko'radi.\"}],\"\\n\",[\"$\",\"h3\",null,{\"children\":\"4. Monogramma tushirilgan korporativ to'plam\"}],\"\\n\",[\"$\",\"p\",null,{\"children\":\"Hamkasblar va ishbilarmon hamkorlar uchun \\\\u2014 monogramma tushirilgan to'plam (ruchka + vizitka qutisi + brelok) qimmat va statusli ko'rinadi.\"}],\"\\n\",[\"$\",\"h3\",null,{\"children\":\"5. Gravirovka qilingan yog'och otkritka\"}],\"\\n\",[\"$\",\"p\",null,{\"children\":\"Shaxsiy matn tushirilgan g'ayrioddiy yog'och otkritka \\\\u2014 uni qog'ozdagidek tashlab yuborishmaydi. Javonda bezak sifatida turadi.\"}],\"\\n\",[\"$\",\"h2\",null,{\"children\":\"To'g'ri sovg'ani qanday tanlash kerak?\"}],\"\\n\",[\"$\",\"p\",null,{\"children\":\"O'zingizga uchta savol bering:\"}],\"\\n\",[\"$\",\"ul\",null,{\"children\":[\"\\n\",[\"$\",\"li\",null,{\"children\":[[\"$\",\"strong\",null,{\"children\":\"Kimga sovg'a qilyapsiz?\"}],\" Onaga, xotinga, hamkasbga yoki rahbarga \\\\u2014 har biriga o'z sovg'asi\"]}],\"\\n\",[\"$\",\"li\",null,{\"children\":[[\"$\",\"strong\",null,{\"children\":\"Qanday byudjet?\"}],\" Bizda 80 000 dan 2 000 000 so'mgacha bo'lgan variantlar mavjud\"]}],\"\\n\",[\"$\",\"li\",null,{\"children\":[[\"$\",\"strong\",null,{\"children\":\"Nima yozish kerak?\"}],\" Ism, sana, iqtibos, tilak \\\\u2014 biz matn bilan yordam beramiz\"]}],\"\\n\"]}],\"\\n\",[\"$\",\"h2\",null,{\"children\":\"Ko'p beriladigan savollar\"}],\"\\n\",[\"$\",\"h3\",null,{\"children\":\"Gravirovkaga rasm qo'shsa bo'ladimi?\"}],\"\\n\",[\"$\",\"p\",null,{\"children\":\"Ha, biz metall va yog'ochga fotogravirovka qilamiz. Telegram orqali rasm yuboring, biz maket tayyorlaymiz.\"}],\"\\n\",[\"$\",\"h3\",null,{\"children\":\"Minimal buyurtma qancha?\"}],\"\\n\",[\"$\",\"p\",null,{\"children\":\"Minimal buyurtma \\\\u2014 1 dona. Miqdor bo'yicha hech qanday cheklovlar yo'q.\"}]]\nb:[[\"$\",\"meta\",\"0\",{\"charSet\":\"utf-8\"}],[\"$\",\"meta\",\"1\",{\"name\":\"viewport\",\"content\":\"width=device-width, initial-scale=1\"}],[\"$\",\"meta\",\"2\",{\"name\":\"theme-color\",\"content\":\"#14b8a6\"}]]\n8:null\n9:null\nd:[[\"$\",\"title\",\"0\",{\"children\":\"8-martga original sovg'alar | Graver Studio | Graver.uz\"}],[\"$\",\"meta\",\"1\",{\"name\":\"description\",\"content\":\"8-martga gravirovka qilingan 5 ta original sovg'a g'oyasi. Soat, zajigalka, ismi tushirilgan taqinchoqlar - Graver Studio, Toshkent.\"}],[\"$\",\"link\",\"2\",{\"rel\":\"canonical\",\"href\":\"https://graver-studio.uz/uz/blog/originalnye-podarki-na-8-marta-uz\"}],[\"$\",\"link\",\"3\",{\"rel\":\"alternate\",\"hrefLang\":\"ru\",\"href\":\"https://graver-studio.uz/ru/blog/originalnye-podarki-na-8-marta\"}],[\"$\",\"link\",\"4\",{\"rel\":\"alternate\",\"hrefLang\":\"uz\",\"href\":\"https://graver-studio.uz/uz/blog/originalnye-podarki-na-8-marta-uz\"}],[\"$\",\"link\",\"5\",{\"rel\":\"alternate\",\"hrefLang\":\"x-default\",\"href\":\"https://graver-studio.uz/ru/blog/originalnye-podarki-na-8-marta-uz\"}],[\"$\",\"meta\",\"6\",{\"property\":\"og:title\",\"content\":\"8-martga original sovg'alar | Graver Studio\"}],[\"$\",\"meta\",\"7\",{\"property\":\"og:description\",\"content\":\"8-martga gravirovka qilingan 5 ta original sovg'a g'oyasi. Soat, zajigalka, ismi tushirilgan taqinchoqlar - Graver Studio, Toshkent.\"}],[\"$\",\"meta\",\"8\",{\"property\":\"og:url\",\"content\":\"https://graver-studio.uz/uz/blog/originalnye-podarki-na-8-marta-uz\"}],[\"$\",\"meta\",\"9\",{\"property\":\"og:site_name\",\"content\":\"Graver.uz\"}],[\"$\",\"meta\",\"10\",{\"property\":\"og:locale\",\"content\":\"uz_UZ\"}],[\"$\",\"meta\",\"11\",{\"property\":\"og:image\",\"content\":\"https://graver-studio.uz/images/blog/originalnye-podarki-na-8-marta-uz.jpg\"}],[\"$\",\"meta\",\"12\",{\"property\":\"og:image:width\",\"content\":\"1200\"}],[\"$\",\"meta\",\"13\",{\"property\":\"og:image:height\",\"content\":\"630\"}],[\"$\",\"meta\",\"14\",{\"property\":\"og:image:alt\",\"content\":\"8-martga original sovg'alar | Graver Studio\"}],[\"$\",\"meta\",\"15\",{\"property\":\"og:type\",\"content\":\"article\"}],[\"$\",\"meta\",\"16\",{\"property\":\"article:published_time\",\"content\":\"2026-03-01\"}],[\"$\",\"meta\",\"17\",{\"property\":\"article:author\",\"content\":\"Graver.uz\"}],[\"$\",\"meta\",\"18\",{\"name\":\"twitter:card\",\"content\":\"summary_large_image\"}],[\"$\",\"meta\",\"19\",{\"name\":\"twitter:title\",\"content\":\"8-martga original sovg'alar | Graver Studio\"}],[\"$\",\"meta\",\"20\",{\"name\":\"twitter:description\",\"content\":\"8-martga gravirovka qilingan 5 ta original sovg'a g'oyasi. Soat, zajigalka, ismi tushirilgan taqinchoqlar - Grav