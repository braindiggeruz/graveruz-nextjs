inchoqlari uchun yog'och quticha\\\"}],\\\"\\\\n\\\",[\\\"$\\\",\\\"p\\\",null,{\\\"children\\\":\\\"Uning ismi yoki \\\\\\\"Mening xazinamga\\\\\\\" iborasi o'yilgan chiroyli qutichani sovg'a qiling. Ichiga yangi taqinchoq solib qo'yish mumkin.\\\"}],\\\"\\\\n\\\",[\\\"$\\\",\\\"h3\\\",null,{\\\"children\\\":\\\"5. Kalitlar uchun juft breloklar\\\"}],\\\"\\\\n\\\",[\\\"$\\\",\\\"p\\\",null,{\\\"children\\\":\\\"Sizning ismlaringiz yoki sanangiz tushirilgan, bir butunni tashkil etuvchi ikkita brelok (masalan, yurakning ikki yarmi) \\\\\\\\u2014 sizning aloqangiz ramzi.\\\"}],\\\"\\\\n\\\",[\\\"$\\\",\\\"h2\\\",null,{\\\"children\\\":\\\"Gravirovka uchun g'oyalar\\\"}],\\\"\\\\n\\\",[\\\"$\\\",\\\"ul\\\",null,{\\\"children\\\":[\\\"\\\\n\\\",[\\\"$\\\",\\\"li\\\",null,{\\\"children\\\":\\\"Sizning ismlaringiz yoki bosh harflaringiz (A+B)\\\"}],\\\"\\\\n\\\",[\\\"$\\\",\\\"li\\\",null,{\\\"children\\\":\\\"Tanishgan yoki turmush qurgan sanangiz\\\"}],\\\"\\\\n\\\",[\\\"$\\\",\\\"li\\\",null,{\\\"children\\\":\\\"Birinchi uchrashuvingiz joyining koordinatalari\\\"}],\\\"\\\\n\\\",[\\\"$\\\",\\\"li\\\",null,{\\\"children\\\":\\\"Qisqa ibora: \\\\\\\"Abadiy\\\\\\\", \\\\\\\"Mening sevgim\\\\\\\", \\\\\\\"Birga\\\\\\\"\\\"}],\\\"\\\\n\\\",[\\\"$\\\",\\\"li\\\",null,{\\\"children\\\":\\\"Cheksizlik belgisi\\\"}],\\\"\\\\n\\\"]}],\\\"\\\\n\\\",[\\\"$\\\",\\\"p\\\",null,{\\\"children\\\":[[\\\"$\\\",\\\"strong\\\",null,{\\\"children\\\":\\\"Qiz do'stingizga unutilmas sovg'a qilmoqchimisiz?\\\"}],\\\" Bizga yozing va biz sizning his-tuyg'ularingizni ifodalaydigan noyob gravirovka qilingan buyumni yaratishga yordam beramiz.\\\"]}],\\\"\\\\n\\\",[\\\"$\\\",\\\"p\\\",null,{\\\"children\\\":[\\\"$\\\",\\\"a\\\",null,{\\\"href\\\":\\\"/#contacts\\\",\\\"children\\\":\\\"Romantik sovg'a yaratish\\\"}]}]]\\n\"])</script><script>self.__next_f.push([1,\"b:[[\\\"$\\\",\\\"meta\\\",\\\"0\\\",{\\\"charSet\\\":\\\"utf-8\\\"}],[\\\"$\\\",\\\"meta\\\",\\\"1\\\",{\\\"name\\\":\\\"viewport\\\