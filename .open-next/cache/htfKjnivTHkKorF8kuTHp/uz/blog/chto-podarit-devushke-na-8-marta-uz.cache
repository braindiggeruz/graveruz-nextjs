tion flex items-center\",\"children\":[\"← \",\"Blogga qaytish\"]}]}]]}]]\nf:[\"$\",\"html\",null,{\"lang\":\"ru\",\"children\":[\"$\",\"body\",null,{\"className\":\"bg-black text-white min-h-screen flex items-center justify-center\",\"children\":[\"$\",\"div\",null,{\"className\":\"text-center px-4\",\"children\":[[\"$\",\"h1\",null,{\"className\":\"text-8xl font-bold text-teal-500 mb-4\",\"children\":\"404\"}],[\"$\",\"h2\",null,{\"className\":\"text-2xl font-semibold text-white mb-4\",\"children\":\"Страница не найдена\"}],[\"$\",\"p\",null,{\"className\":\"text-gray-400 mb-8\",\"children\":\"Запрошенная страница не существует.\"}],[\"$\",\"$L12\",null,{\"href\":\"/ru\",\"className\":\"bg-gradient-to-r from-teal-500 to-cyan-600 text-white px-6 py-3 rounded-lg font-semibold hover:opacity-90 transition\",\"children\":\"На главную\"}]]}]}]}]\n11:[\"$\",\"div\",null,{\"className\":\"min-h-screen flex items-center justify-center px-4\",\"children\":[\"$\",\"div\",null,{\"className\":\"text-center\",\"children\":[[\"$\",\"h1\",null,{\"className\":\"text-8xl font-bold text-teal-500 mb-4\",\"children\":\"404\"}],[\"$\",\"h2\",null,{\"className\":\"text-2xl font-semibold text-white mb-4\",\"children\":\"Страница не найдена\"}],[\"$\",\"p\",null,{\"className\":\"text-gray-400 mb-8\",\"children\":\"Запрошенная страница не существует.\"}],[\"$\",\"$L12\",null,{\"href\":\"/ru\",\"className\":\"bg-gradient-to-r from-teal-500 to-cyan-600 text-white px-6 py-3 rounded-lg font-semibold hover:opacity-90 transition\",\"children\":\"На главную\"}]]}]}]\n13:[[\"$\",\"h2\",null,{\"children\":\"8-martda qiz do'stingizni qanday hayratda qoldirish mumkin?\"}],\"\\n\",[\"$\",\"p\",null,{\"children\":\"8-mart \\\\u2014 bu sizning qiz do'stingizga u qanchalik o'zgacha ekanligini ko'rsatishni istaydigan kun. Gullar va restoran \\\\u2014 bu ajoyib, lekin uzoq vaqt saqlanib qoladigan va sizning his-tuyg'ularingizni eslatib turadigan sovg'a \\\\u2014 bu butunlay boshqa daraja. Shaxsiy gravirovka oddiy narsani sizning sevgingizning noyob ramziga aylantiradi.\"}],\"\\n\",[\"$\",\"h2\",null,{\"children\":\"Gravirovka qilingan 5 ta eng romantik sovg'a g'oyasi\"}],\"\\n\",[\"$\",\"h3\",null,{\"children\":\"1. Sizning bosh harflaringiz tushirilgan kulon yoki bilaguzuk\"}],\"\\n\",[\"$\",\"p\",null,{\"children\":\"Bu eng mashhur romantik sovg'a. Sizning bosh harflaringiz, tanishgan sanangiz yoki \\\"Sevaman\\\" so'zi o'yilgan kichik kulon yoki bilaguzuk \\\\u2014 bu u yechishni istamaydigan taqinchoq.\"}],\"\\n\",[\"$\",\"h3\",null,{\"children\":\"2. Orqa qopqog'ida gravirovkasi bo'lgan soat\"}],\"\\n\",[\"$\",\"p\",null,{\"children\":\"\\\"Sen bilan vaqtni yo'qotaman\\\" yoki \\\"Sen bilan har bir soniya \\\\u2014 baxt\\\". Soatning orqa qopqog'idagi bunday ibora \\\\u2014 bu juda samimiy va ta'sirli ishora.\"}],\"\\n\",[\"$\",\"h3\",null,{\"children\":\"3. Maqtov so'zli sumka oynasi\"}],\"\\n\",[\"$\",\"p\",null,{\"children\":\"Har safar oynani chiqarganda, u \\\"Sen go'zalsan\\\" degan gravirovkani ko'radi va sizni eslab tabassum qiladi.\"}],\"\\n\",[\"$\",\"h3\",null,{\"children\":\"4. Uning taqinchoqlari uchun yog'och quticha\"}],\"\\n\",[\"$\",\"p\",null,{\"children\":\"Uning ismi yoki \\\"Mening xazinamga\\\" iborasi o'yilgan chiroyli qutichani sovg'a qiling. Ichiga yangi taqinchoq solib qo'yish mumkin.\"}],\"\\n\",[\"$\",\"h3\",null,{\"children\":\"5. Kalitlar uchun juft breloklar\"}],\"\\n\",[\"$\",\"p\",null,{\"children\":\"Sizning ismlaringiz yoki sanangiz tushirilgan, bir butunni tashkil etuvchi ikkita brelok (masalan, yurakning ikki yarmi) \\\\u2014 sizning aloqangiz ramzi.\"}],\"\\n\",[\"$\",\"h2\",null,{\"children\":\"Gravirovka uchun g'oyalar\"}],\"\\n\",[\"$\",\"ul\",null,{\"children\":[\"\\n\",[\"$\",\"li\",null,{\"children\":\"Sizning ismlaringiz yoki bosh harflaringiz (A+B)\"}],\"\\n\",[\"$\",\"li\",null,{\"children\":\"Tanishgan yoki turmush qurgan sanangiz\"}],\"\\n\",[\"$\",\"li\",null,{\"children\":\"Birinchi uchrashuvingiz joyining koordinatalari\"}],\"\\n\",[\"$\",\"li\",null,{\"children\":\"Qisqa ibora: \\\"Abadiy\\\", \\\"Mening sevgim\\\", \\\"Birga\\\"\"}],\"\\n\",[\"$\",\"li\",null,{\"children\":\"Cheksizlik belgisi\"}],\"\\n\"]}],\"\\n\",[\"$\",\"p\",null,{\"children\":[[\"$\",\"strong\",null,{\"children\":\"Qiz do'stingizga unutilmas sovg'a qilmoqchimisiz?\"}],\" Bizga yozing va biz sizning his-tuyg'ularingizni ifodalaydigan noyob gravirovka qilingan buyumni yaratishga yordam beramiz.\"]}],\"\\n\",[\"$\",\"p\",null,{\"children\":[\"$\",\"a\",null,{\"href\":\"/#contacts\",\"children\":\"Romantik sovg'a yaratish\"}]}]]\nb:[[\"$\",\"meta\",\"0\",{\"charSet\":\"utf-8\"}],[\"$\",\"meta\",\"1\",{\"name\":\"viewport\",\"content\":\"width=device-width, initial-scale=1\"}],[\"$\",\"meta\",\"2\",{\"name\":\"theme-color\",\"content\":\"#14b8a6\"}]]\n8:null\n9:null\nd:[[\"$\",\"title\",\"0\",{\"children\":\"8-martga qiz do'stga nima sovg'a qilish kerak | Graver Studio | Graver.uz\"}],[\"$\",\"meta\",\"1\",{\"name\":\"description\",\"content\":\"Qiz do'stga 8-martga romantik sovg'alar gravirovka bilan. Bosh harflari tushirilgan taqinchoqlar, e'tirof bitilgan soat, juft breloklar. Kunini unutilmas qiling.\"}],[\"$\",\"link\",\"2\",{\"rel\":\"canonical\",\"href\":\"https://graver-studio.uz/uz/blog/chto-podarit-devushke-na-8-marta-uz\"}],[\"$\",\"link\",\"3\",{\"rel\":\"alternate\",\"hrefLang\":\"ru\",\"href\":\"https://graver-studio.uz/ru/blog/chto-podarit-devushke-na-8-marta\"}],[\"$\",\"link\",\"4\",{\"rel\":\"alternate\",\"hrefLang\":\"uz\",\"href\":\"https://graver-studio.uz/uz/blog/chto-podarit-devushke-na-8-marta-uz\"}],[\"$\",\"link\",\"5\",{\"rel\":\"alternate\",\"hrefLang\":\"x-default\",\"href\":\"https://graver-studio.uz/ru/blog/chto-podarit-devushke-na-8-marta-uz\"}],[\"$\",\"meta\",\"6\",{\"property\":\"og:title\",\"content\":\"8-martga qiz do'stga nima sovg'a qilish kerak | Graver Studio\"}],[\"$\",\"meta\",\"7\",{\"property\":\"og:description\",\"content\":\"Qiz do'stga 8-martga romantik sov